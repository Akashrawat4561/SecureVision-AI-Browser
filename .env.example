# ============================================================
#  SecureVision AI — Environment Variables Example
#  Copy this file to .env and fill in your values.
#  NEVER commit the real .env file to version control!
# ============================================================

# --- BACKEND / INFERENCE SETTINGS ---
REDIS_HOST=redis
REDIS_PORT=6379
DEEPFAKE_MODEL_PATH=/app/models/xception_deepfake.onnx
ENV=development                         # development | production

# --- FRONTEND SETTINGS (Vite) ---
VITE_API_BASE_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8000/ws

# --- HONEYPOT SETTINGS ---
HONEYPOT_PORT=2222
HONEYPOT_NODE_ID=pi-honeypot-main

# --- PREDICTIVE SIMULATION ---
SLM_MODEL=gpt2
SIM_BATCH_SIZE=4




